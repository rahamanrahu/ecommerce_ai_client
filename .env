# Client environment variables for development
# Use REACT_APP_ prefix so Create React App exposes them to the app
REACT_APP_API_URL=http://localhost:5000
REACT_APP_CLIENT_URL=http://localhost:3000

# Optional placeholders (fill in production values before deploy)
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_STRIPE_PUBLISHABLE_KEY=
REACT_APP_SENTRY_DSN=

# Feature flags
REACT_APP_ENABLE_EXPERIMENTAL=false
